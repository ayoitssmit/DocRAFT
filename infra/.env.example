# ── DocRAFT Infrastructure Environment Variables ─────────────────────────────
# Copy this file to .env (in the repo root or infra/ dir) and fill in values.

# Ollama (runs on host, accessed from Docker via host.docker.internal)
OLLAMA_HOST=http://host.docker.internal:11434
MODEL_NAME=qwen2.5-coder:7b
EMBED_MODEL=nomic-embed-text
VISION_MODEL=granite3.2-vision:2b

# Qdrant (managed by docker-compose — no changes needed)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
