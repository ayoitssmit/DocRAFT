# ── DocRAFT Infrastructure Environment Variables ─────────────────────────────
# Copy this file to .env (in the repo root or infra/ dir) and fill in values.

# Ollama (runs on host)
# Use http://127.0.0.1:11434 for local, or http://host.docker.internal:11434 for Docker
OLLAMA_HOST=http://127.0.0.1:11434
MODEL_NAME=qwen2.5-coder:7b
EMBED_MODEL=nomic-embed-text
VISION_MODEL=granite3.2-vision:2b

# Qdrant (Set to '127.0.0.1' for local disk mode or 'vector-db' for Docker)
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
ENVIRONMENT=development
